# Copy this file to .env (for local `vercel dev`) — never commit the real .env.
# In production, set these as Environment Variables in the Vercel project
# dashboard instead (Settings → Environment Variables). Never paste real
# secrets into this file if you intend to commit it.

# Notion internal integration token (starts with "secret_" or "ntn_").
# Create at: https://www.notion.so/my-integrations
NOTION_TOKEN=

# The data source (collection) ID for the "Smart Tender Content Library" database.
# Defaults to the value already wired into api/library.js if left unset.
NOTION_DATA_SOURCE_ID=379063cc-a383-8042-8559-000bb1987a05
